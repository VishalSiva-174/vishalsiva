<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vishal Siva — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --p: #00F5D4;
  --s: #4361EE;
  --a: #7209B7;
  --bg: #0A0A0A;
  --bg2: #111111;
  --bg3: #181818;
  --text: #F0F0F0;
  --muted: #888;
  --border: rgba(255,255,255,0.08);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Space Grotesk',sans-serif;overflow-x:hidden;cursor:none}

/* Custom cursor */
#cursor{position:fixed;width:12px;height:12px;background:var(--p);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform 0.1s ease,background 0.2s;mix-blend-mode:difference}
#cursor-ring{position:fixed;width:40px;height:40px;border:1px solid var(--p);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:transform 0.15s ease,width 0.2s,height 0.2s,opacity 0.2s;opacity:0.5}

/* Scroll progress */
#progress{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,var(--p),var(--s));z-index:1000;width:0%;transition:width 0.1s}

/* Nav */
nav{position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:900;background:rgba(10,10,10,0.7);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:50px;padding:12px 28px;display:flex;gap:28px;align-items:center}
nav a{color:var(--muted);text-decoration:none;font-size:13px;font-weight:500;transition:color 0.2s;letter-spacing:0.02em}
nav a:hover{color:var(--p)}
nav .nav-name{color:var(--text);font-weight:600;font-size:14px;margin-right:12px;font-family:'Syne',sans-serif}

/* Canvas */
#canvas{position:fixed;top:0;left:0;pointer-events:none;z-index:0}

/* Sections */
section{position:relative;z-index:1}

/* Hero */
#hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:120px 20px 80px}
.hero-inner{max-width:900px}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(0,245,212,0.07);border:1px solid rgba(0,245,212,0.2);border-radius:50px;padding:6px 16px;font-size:12px;color:var(--p);margin-bottom:32px;letter-spacing:0.05em;font-family:'JetBrains Mono',monospace}
.hero-badge::before{content:'';width:6px;height:6px;background:var(--p);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
h1{font-family:'Syne',sans-serif;font-size:clamp(48px,8vw,96px);font-weight:800;line-height:1.0;letter-spacing:-0.03em;margin-bottom:24px}
.grad{background:linear-gradient(135deg,#fff 0%,var(--p) 50%,var(--s) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:clamp(16px,2vw,20px);color:var(--muted);max-width:600px;margin:0 auto 16px;line-height:1.6}
.typed-wrap{font-size:clamp(14px,1.8vw,18px);color:var(--p);font-family:'JetBrains Mono',monospace;margin-bottom:48px;height:28px}
#typed-cursor{animation:blink 1s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:50px;font-size:14px;font-weight:600;text-decoration:none;transition:all 0.3s;cursor:none;border:none;font-family:'Space Grotesk',sans-serif}
.btn-primary{background:var(--p);color:#000}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 20px 40px rgba(0,245,212,0.3)}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border)}
.btn-outline:hover{border-color:var(--p);color:var(--p);transform:translateY(-2px)}
.scroll-hint{margin-top:80px;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0.4;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.scroll-hint span{font-size:11px;letter-spacing:0.1em;color:var(--muted)}
.arrow-down{width:1px;height:40px;background:linear-gradient(to bottom,transparent,var(--p))}

/* Sections shared */
.section{padding:120px 20px}
.container{max-width:1100px;margin:0 auto}
.section-label{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--p);letter-spacing:0.1em;margin-bottom:16px;display:block}
.section-title{font-family:'Syne',sans-serif;font-size:clamp(32px,5vw,56px);font-weight:800;margin-bottom:16px;letter-spacing:-0.02em}
.section-sub{color:var(--muted);font-size:16px;max-width:500px;line-height:1.6;margin-bottom:64px}
.divider{width:40px;height:2px;background:var(--p);margin-bottom:32px}

/* About */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.about-text p{color:rgba(240,240,240,0.7);line-height:1.8;margin-bottom:20px;font-size:16px}
.about-stats{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:48px}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:24px;transition:border-color 0.3s}
.stat-card:hover{border-color:rgba(0,245,212,0.3)}
.stat-num{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;color:var(--p);display:block}
.stat-label{font-size:12px;color:var(--muted);margin-top:4px}
.edu-card{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:32px}
.edu-card h3{font-family:'Syne',sans-serif;font-size:20px;margin-bottom:8px}
.edu-college{color:var(--p);font-size:14px;margin-bottom:16px}
.edu-detail{color:var(--muted);font-size:14px;display:flex;gap:20px}
.cgpa{background:rgba(0,245,212,0.1);border:1px solid rgba(0,245,212,0.2);border-radius:8px;padding:4px 12px;font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--p)}

/* Skills */
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px}
.skill-cat{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:28px;transition:all 0.3s}
.skill-cat:hover{border-color:rgba(67,97,238,0.4);transform:translateY(-4px)}
.cat-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;font-size:20px}
.cat-icon.teal{background:rgba(0,245,212,0.1)}
.cat-icon.blue{background:rgba(67,97,238,0.1)}
.cat-icon.purple{background:rgba(114,9,183,0.1)}
.cat-icon.pink{background:rgba(247,37,133,0.1)}
.skill-cat h3{font-size:14px;font-weight:600;margin-bottom:16px;color:var(--muted);letter-spacing:0.05em;text-transform:uppercase;font-family:'JetBrains Mono',monospace;font-size:11px}
.skill-tags{display:flex;flex-wrap:wrap;gap:8px}
.tag{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:8px;padding:5px 12px;font-size:13px;transition:all 0.2s}
.tag:hover{background:rgba(0,245,212,0.08);border-color:rgba(0,245,212,0.3);color:var(--p)}

/* Projects */
.projects-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.proj-card{background:var(--bg2);border:1px solid var(--border);border-radius:24px;padding:36px;transition:all 0.4s;position:relative;overflow:hidden}
.proj-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--p),transparent);opacity:0;transition:opacity 0.3s}
.proj-card:hover{border-color:rgba(0,245,212,0.2);transform:translateY(-6px)}
.proj-card:hover::before{opacity:1}
.proj-num{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--p);opacity:0.6;margin-bottom:16px}
.proj-title{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;margin-bottom:12px;letter-spacing:-0.01em}
.proj-desc{color:rgba(240,240,240,0.6);font-size:15px;line-height:1.7;margin-bottom:24px}
.proj-features{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px}
.feature-tag{background:rgba(67,97,238,0.1);border:1px solid rgba(67,97,238,0.2);border-radius:6px;padding:4px 10px;font-size:12px;color:#8899FF}
.tech-stack{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:24px}
.tech-tag{background:rgba(114,9,183,0.08);border:1px solid rgba(114,9,183,0.2);border-radius:6px;padding:4px 10px;font-size:12px;color:#BB77FF}
.proj-links{display:flex;gap:12px}
.proj-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:var(--p);text-decoration:none;opacity:0.8;transition:opacity 0.2s}
.proj-link:hover{opacity:1}

/* Timeline */
.timeline{position:relative;padding-left:40px}
.timeline::before{content:'';position:absolute;left:0;top:8px;bottom:0;width:1px;background:linear-gradient(to bottom,var(--p),rgba(0,245,212,0))}
.tl-item{position:relative;margin-bottom:48px}
.tl-dot{position:absolute;left:-44px;top:6px;width:10px;height:10px;background:var(--p);border-radius:50%;box-shadow:0 0 16px rgba(0,245,212,0.5)}
.tl-year{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--p);margin-bottom:8px}
.tl-role{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:4px}
.tl-org{color:var(--muted);font-size:14px}

/* Certifications */
.certs-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}
.cert-card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:24px;transition:all 0.3s;position:relative}
.cert-card:hover{border-color:rgba(0,245,212,0.3);transform:translateY(-3px)}
.cert-issuer{font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--p);letter-spacing:0.05em;margin-bottom:8px}
.cert-name{font-size:14px;font-weight:600;line-height:1.4}
.cert-badge{position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px}

/* Internship */
.intern-card{background:linear-gradient(135deg,rgba(0,245,212,0.05) 0%,rgba(67,97,238,0.05) 100%);border:1px solid rgba(0,245,212,0.15);border-radius:24px;padding:48px;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.intern-logo{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--p);margin-bottom:8px}
.intern-sub{color:var(--muted);font-size:14px;margin-bottom:24px}
.intern-desc{color:rgba(240,240,240,0.7);line-height:1.8;font-size:16px}
.intern-tags{display:flex;flex-wrap:wrap;gap:8px}
.intern-tag{background:rgba(0,245,212,0.08);border:1px solid rgba(0,245,212,0.2);border-radius:8px;padding:6px 14px;font-size:13px;color:var(--p)}

/* Contact */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.contact-form{background:var(--bg2);border:1px solid var(--border);border-radius:24px;padding:40px}
.form-group{margin-bottom:20px}
.form-group label{display:block;font-size:12px;color:var(--muted);margin-bottom:8px;font-family:'JetBrains Mono',monospace;letter-spacing:0.05em}
.form-group input,.form-group textarea{width:100%;background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:12px;padding:14px 16px;color:var(--text);font-size:14px;font-family:'Space Grotesk',sans-serif;outline:none;transition:border-color 0.2s}
.form-group input:focus,.form-group textarea:focus{border-color:rgba(0,245,212,0.4)}
.form-group textarea{height:120px;resize:vertical}
.contact-links{display:flex;flex-direction:column;gap:16px;margin-top:32px}
.contact-link{display:flex;align-items:center;gap:16px;padding:20px 24px;background:var(--bg2);border:1px solid var(--border);border-radius:16px;text-decoration:none;color:var(--text);transition:all 0.3s;cursor:none}
.contact-link:hover{border-color:rgba(0,245,212,0.3);transform:translateX(6px)}
.cl-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.cl-label{font-size:11px;color:var(--muted);margin-bottom:2px}
.cl-val{font-size:14px;font-weight:600}

/* Footer */
footer{border-top:1px solid var(--border);padding:40px 20px;text-align:center;color:var(--muted);font-size:13px}
footer span{color:var(--p)}

/* Animations */
.reveal{opacity:0;transform:translateY(30px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* Spotlight */
.spotlight{position:fixed;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(0,245,212,0.04) 0%,transparent 70%);pointer-events:none;z-index:0;transform:translate(-50%,-50%);transition:left 0.3s ease,top 0.3s ease}

@media(max-width:768px){
  .about-grid,.projects-grid,.contact-grid,.intern-card{grid-template-columns:1fr}
  nav .nav-links{display:none}
}
</style>
</head>
